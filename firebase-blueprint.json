{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["userId", "email"]
    },
    "ESIMUsage": {
      "title": "eSIM Usage",
      "description": "Real-time eSIM data usage",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "esimId": { "type": "string" },
        "consumedDataGB": { "type": "number" },
        "totalDataGB": { "type": "number" }
      },
      "required": ["userId", "esimId", "consumedDataGB", "totalDataGB"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/esimUsage/{esimId}": {
      "schema": "ESIMUsage",
      "description": "Real-time eSIM data usage"
    }
  }
}
